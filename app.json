{
  "expo": {
    "name": "TradeTalk",
    "slug": "tradetalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "tradetalk",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tradetalk.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "TradeTalk uses FaceID to provide quick and secure access to your account.",
        "NSCameraUsageDescription": "TradeTalk needs access to your camera to upload product photos and media.",
        "NSPhotoLibraryUsageDescription": "TradeTalk needs access to your photos to upload product photos and media.",
        "NSMicrophoneUsageDescription": "TradeTalk needs access to your microphone to record voice messages in chat."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tradetalk.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow TradeTalk to use FaceID"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TradeTalk to access your photos",
          "cameraPermission": "Allow TradeTalk to access your camera"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow TradeTalk to access your microphone for voice messages."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2255ee"
        }
      ],
      "expo-font",
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7cf8412-3e30-4d59-91c4-8a4b7f3f0c52"
      }
    }
  }
}